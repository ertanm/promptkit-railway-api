{
  "name": "promptextension-api",
  "version": "1.0.0",
  "main": "dist/index.js",
  "license": "MIT",
  "scripts": {
    "start": "node dist/index.js",
    "build": "prisma generate && tsc",
    "postbuild": "prisma migrate deploy",
    "dev": "nodemon index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "migrate:deploy": "prisma migrate deploy"
  },
  "nodemonConfig": {
    "exec": "tsx",
    "ext": "ts,json",
    "watch": [
      "*.ts"
    ]
  },
  "dependencies": {
    "@clerk/express": "^2.0.4",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@sentry/node": "^10.43.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "ioredis": "^5.10.0",
    "morgan": "^1.10.0",
    "pg": "^8.20.0",
    "rate-limit-redis": "^4.3.1",
    "stripe": "^20.4.1",
    "prisma": "^7.5.0",
    "tsx": "^4.19.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/morgan": "^1.9.9",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^7.2.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
