{
  "name": "promptextension",
  "displayName": "PromptVault",
  "version": "0.1.0",
  "description": "Save, organize, and inject AI prompts into any chat interface.",
  "author": "Highpriesst",
  "manifest": {
    "content_security_policy": {
      "extension_pages": "script-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none';"
    },
    "host_permissions": [
      "https://chat.openai.com/*",
      "https://chatgpt.com/*",
      "https://claude.ai/*",
      "https://v0.dev/*",
      "https://promptkit-railway-api-production.up.railway.app/*"
    ]
  },
  "scripts": {
    "dev": "plasmo dev",
    "dev:firefox": "plasmo dev --target=firefox-mv2",
    "build": "plasmo build",
    "build:prod": "cross-env NODE_ENV=production plasmo build",
    "build:firefox": "plasmo build --target=firefox-mv2",
    "package": "plasmo package",
    "package:firefox": "plasmo package --target=firefox-mv2",
    "build:all": "plasmo build && plasmo build --target=firefox-mv2",
    "verify:manifest": "ts-node scripts/verify-prod-manifest.ts",
    "verify:prod-manifest": "ts-node scripts/verify-prod-manifest.ts",
    "zip:prod": "bash scripts/zip-prod.sh"
  },
  "dependencies": {
    "@clerk/chrome-extension": "^3.1.2",
    "@fontsource/dm-mono": "^5.2.7",
    "@fontsource/dm-sans": "^5.2.8",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "plasmo": "0.90.5",
    "prisma": "^7.5.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "autoprefixer": "^10.4.27",
    "cross-env": "^10.1.0",
    "postcss": "^8.5.8",
    "prettier": "3.2.4",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  }
}
