# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/promptvault?schema=public

# Clerk Auth
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Redis (Sprint 4+)
# REDIS_URL=redis://localhost:6379

# Stripe (Sprint 5+)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Server
PORT=3000
NODE_ENV=development

# Comma-separated list of allowed origins. Required in production.
# REQUIRED IN PRODUCTION — leaving this empty allows all browser origins
# Example: CORS_ORIGINS=https://yourdomain.com,chrome-extension://YOUR_EXTENSION_ID
CORS_ORIGINS=

# Dev only — never set to true in staging or production
ALLOW_DEV_AUTO_AUTH=false

# Production API URL. Set this before running build:prod.
# Example: PLASMO_PUBLIC_API_URL=https://api.yourdomain.com
PLASMO_PUBLIC_API_URL=
